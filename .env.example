# Contact form (src/pages/api/contact.ts) — set these in Vercel → Project → Settings → Environment Variables.
# Read at RUNTIME via process.env, so they do NOT need to be present at build time.

# Required: Resend API key. https://resend.com/api-keys
RESEND_API_KEY=

# Optional: who receives enquiries. Defaults to contact@yimei-env.com.
CONTACT_NOTIFY_TO=

# Optional: the "from" address. Defaults to onboarding@resend.dev (works with no
# domain setup). Once you verify a domain in Resend, set e.g. "Yimei <noreply@yourdomain>".
RESEND_FROM=

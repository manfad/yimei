---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

// Board of directors. Lead directors are shown with a photo; the rest as
// name + WhatsApp + email contact actions.
const leadDirectors = [
  { name: 'Datuk Yap Yun Fook', role: 'Managing Director', photo: '/images/directors/director-1.png' },
  { name: 'Mr Chen', role: 'Director · Qingdao Yimei', photo: '/images/directors/director-2.png' },
];

const directors = [
  { name: 'Mr Yap', phone: '60186655655', email: 'sync.dyna@gmail.com' },
  { name: 'Mr Yap Kim Hui', phone: '60168132173', email: 'ykhui0418@gmail.com' },
];

// Phone taps open WhatsApp with a pre-filled message noting the lead came from the site.
const WHATSAPP_PRETEXT = "Hi, I'm reaching out from yimei.my.";
const waHref = (phone: string) =>
  `https://wa.me/${phone.replace(/\D/g, '')}?text=${encodeURIComponent(WHATSAPP_PRETEXT)}`;
const mailHref = (email: string) => `mailto:${email}`;
const displayPhone = (phone: string) => {
  const digits = phone.replace(/\D/g, '');
  const local = digits.startsWith('60') ? digits.slice(2) : digits;
  const op = local.slice(0, 2);
  const rest = local.slice(2);
  const grouped = rest.length > 3 ? `${rest.slice(0, 3)} ${rest.slice(3)}` : rest;
  return `+60 ${op}-${grouped}`;
};
---

<BaseLayout title="About — Yimei Environment Protection">
  <section class="section">
    <div class="container">
      <PageHero
        eyebrow="About Yimei"
        title="Global treatment expertise, built for Malaysian industry."
        lead="Yimei Environment Protection Sdn Bhd is a Malaysian joint venture that pairs strong local presence with the engineering and manufacturing strength of Qingdao Yimei Environment Project Co., Ltd."
        crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
      />

      <div class="reveal about-bg">
        <div class="about-intro">
          <p class="eyebrow">Our background</p>
          <h2 class="h-lg" style="margin-top:16px;color:#fff">Two companies, one mission for cleaner water.</h2>
          <p class="lead" style="margin-top:18px">
            Yimei Environment Protection Technology Sdn. Bhd. was formed as a joint venture — two companies coming
            together as shareholders to bring proven water and wastewater treatment technology to Malaysia.
          </p>
          <p style="margin-top:16px;color:var(--muted)">
            Our partner, Qingdao Yimei Environment Project Co., Ltd., has engineered environmental systems since 1988,
            completing more than 500 projects across 40+ countries. As they expand into Malaysia, they needed a partner
            with deep local roots, market knowledge and on-the-ground delivery — and that is exactly what we provide.
            Together we combine world-class engineering with local presence and service.
          </p>
        </div>
        <img class="about-bg-art" src="/sketch3.png" alt="" loading="lazy" decoding="async" />
      </div>

      <div class="partners">
        <article class="partner-card reveal">
          <span class="pc-flag">Kota Kinabalu, Sabah</span>
          <h3>Yimei Environment Protection Technology Sdn.&nbsp;Bhd.</h3>
          <p class="pc-role">Local partner &amp; shareholder</p>
          <p>
            The Malaysian foundation of the joint venture, based in Kota Kinabalu, Sabah — providing the local presence,
            relationships and delivery capability that turn proven technology into working plants on the ground.
          </p>
          <ul class="pc-points">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6FC23A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>Supply of water, treatment chemicals &amp; engineering works</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6FC23A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>Project delivery, installation &amp; commissioning</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6FC23A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>After-sales service &amp; ongoing support</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6FC23A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>Regulatory &amp; compliance knowledge</span>
            </li>
          </ul>
        </article>

        <div class="partner-join" aria-hidden="true"><span>+</span></div>

        <article class="partner-card reveal">
          <span class="pc-flag">China · since 1988</span>
          <h3>Qingdao Yimei Environment Project Co.,&nbsp;Ltd.</h3>
          <p class="pc-role">Technology &amp; manufacturing partner</p>
          <p>
            A global environmental equipment manufacturer bringing decades of engineering, a deep product range and an
            international track record to the partnership.
          </p>
          <ul class="pc-points">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>Engineering &amp; manufacturing since 1988</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>500+ treatment projects in 40+ countries</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>130+ types of machinery, 215 patents</span>
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>ISO&nbsp;9001 · CE · TÜV · ASME certified</span>
            </li>
          </ul>
          <a class="textlink" href="https://www.ccyimei.com/About-us" target="_blank" rel="noopener noreferrer" style="margin-top:22px">
            Visit ccyimei.com <span class="arr">&rarr;</span>
          </a>
        </article>
      </div>

    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="reveal" style="max-width:60ch">
        <p class="eyebrow">Our purpose</p>
        <h2 class="h-lg" style="margin-top:16px;color:#fff">Vision &amp; mission</h2>
      </div>
      <div class="vm-grid">
        <div class="vm-card reveal">
          <span class="tag">01</span>
          <div class="vm-ico">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
            </svg>
          </div>
          <h3>Our Vision</h3>
          <p>
            A world where industry operates in a closed loop — where no drop of water is wasted and every waste stream
            becomes a resource. We see effluent not as a problem to discharge, but as water waiting to be recovered.
          </p>
        </div>
        <div class="vm-card leaf reveal">
          <span class="tag">02</span>
          <div class="vm-ico">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6FC23A" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3s6 5.5 6 10a6 6 0 0 1-12 0c0-4.5 6-10 6-10Z"></path>
              <path d="M12 21v-7"></path>
            </svg>
          </div>
          <h3>Our Mission</h3>
          <p>
            To bring proven, modular treatment technology to Malaysian industry — helping mills and factories meet
            discharge standards, recover reusable water and reduce their footprint, backed by service that keeps systems
            running.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="reveal" style="max-width:60ch">
        <p class="eyebrow">Leadership</p>
        <h2 class="h-lg" style="margin-top:16px;color:#fff">Board of directors</h2>
        <p class="lead" style="margin-top:16px">The people steering Yimei's growth in Malaysia.</p>
      </div>
      <div class="board-row">
        {
          leadDirectors.map((director) => (
            <article class="lead-dir reveal">
              {director.photo ? (
                <img class="lead-dir__photo" src={director.photo} alt={director.name} loading="lazy" decoding="async" />
              ) : (
                <div class="ph ph--center lead-dir__photo" data-label="Photo" />
              )}
              <div class="lead-dir__info">
                <h4>{director.name}</h4>
                <p class="lead-dir__role">{director.role}</p>
              </div>
            </article>
          ))
        }
        <div class="board-contacts">
          {
            directors.map((director) => (
            <article class="contact-dir reveal">
              <h4>{director.name}</h4>
              <div class="contact-actions">
                <a class="contact-btn contact-btn--wa" href={waHref(director.phone)} target="_blank" rel="noopener noreferrer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.886-1.02zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"></path>
                  </svg>
                  <span>{displayPhone(director.phone)}</span>
                </a>
                <a class="contact-btn contact-btn--mail" href={mailHref(director.email)}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m22 7-10 6L2 7"></path>
                  </svg>
                  <span>{director.email}</span>
                </a>
              </div>
            </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

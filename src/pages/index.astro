---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Yimei Environment Protection — Water & Wastewater Treatment in Malaysia"
  description="Yimei Environment Protection Technology supplies industrial water and wastewater treatment systems across Malaysia and Sabah — turning effluent and heavy industrial waste into clean, reusable water."
  keywords={[
    'Yimei',
    'Yimei Environment Protection',
    'water treatment Malaysia',
    'wastewater treatment Sabah',
    'water treatment Keningau',
    'Qingdao Yimei',
    'environment protection technology',
  ]}
>
  <section class="hero">
    <div class="container hero-stage">
      <h1 class="hero-title" data-hero-item>
        Waste in.<br /><span class="accent">Water out.</span>
      </h1>

      <figure class="hero-sketch" data-hero-item>
        <img
          src="/sketch2.png"
          width="1745"
          height="901"
          alt="Isometric illustration of a Yimei industrial water treatment facility"
        />
      </figure>

      <div class="hero-desc">
        <p class="hero-tagline" data-hero-item>
          With Yimei, <span class="leaf">We Eco</span>
        </p>
        <p class="lead" data-hero-item>
          Yimei Environment Protection Technology supplies the water-treatment systems that turn effluent and heavy
          industrial waste into clean water — cutting water pollution and giving every drop a second life.
        </p>
        <div class="hero-actions" data-hero-item>
          <a class="btn" href="/products">Explore our solutions <span class="arr">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section nav-section">
    <div class="container">
      <div class="reveal" style="max-width:62ch">
        <p class="eyebrow">Explore Yimei</p>
        <h2 class="h-xl" style="margin-top:18px;color:#fff">Where would you like to go?</h2>
        <p class="lead" style="margin-top:18px">
          Four ways into Yimei — get to know us, browse the full range of treatment solutions, see where we've been, or
          start a conversation.
        </p>
      </div>
      <div class="navcards">
        <a class="navcard reveal" href="/about">
          <div class="nc-no">01</div>
          <h3>About Yimei</h3>
          <p>Our vision, mission, the story behind the company and the people leading it.</p>
          <span class="go">Read more <span class="arr">&rarr;</span></span>
        </a>
        <a class="navcard reveal" href="/products">
          <div class="nc-no">02</div>
          <h3>Products</h3>
          <p>Five categories of treatment flows and equipment — explore the full range.</p>
          <span class="go">Browse range <span class="arr">&rarr;</span></span>
        </a>
        <a class="navcard reveal" href="/events">
          <div class="nc-no">03</div>
          <h3>Events</h3>
          <p>Collaborations, site visits and milestones from across our network.</p>
          <span class="go">See highlights <span class="arr">&rarr;</span></span>
        </a>
        <a class="navcard reveal" href="/contact">
          <div class="nc-no">04</div>
          <h3>Contact</h3>
          <p>Tell us about your site and waste streams — we'll scope a solution.</p>
          <span class="go">Get in touch <span class="arr">&rarr;</span></span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Yimei — Water & Wastewater Treatment Enquiries | Sabah, Malaysia"
  description="Contact Yimei Environment Protection in Kota Kinabalu, Sabah. Share your site and effluent profile and our engineers will scope the right water and wastewater treatment solution for your facility in Malaysia."
  keywords={[
    'contact Yimei',
    'water treatment enquiry Malaysia',
    'wastewater treatment Sabah contact',
    'water treatment supplier Kota Kinabalu',
    'water treatment Keningau',
  ]}
>
  <section class="section">
    <div class="container">
      <PageHero
        eyebrow="Get in touch"
        title="Tell us about your waste stream."
        lead="Share your site details and effluent profile and our engineers will get back to you with the right treatment approach."
        crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
      />

      <div class="contact-grid">
        <div class="reveal">
        <h2 class="h-md" style="color:#fff">Contact details</h2>
        <p class="muted" style="margin-top:14px;max-width:38ch">
          Prefer to reach us directly? Use the details below — we typically reply within one business day.
        </p>
        <div class="info-block">
          <div class="info-item">
            <div class="ii-ico">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div>
              <div class="k">Office</div>
              <div class="v">Lot 20, 2nd Floor, Likas Plaza, Phase 2,<br />Likas, Kota Kinabalu, Sabah</div>
            </div>
          </div>
          <div class="info-item">
            <div class="ii-ico">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16v16H4z"></path>
                <path d="m4 7 8 6 8-6"></path>
              </svg>
            </div>
            <div>
              <div class="k">Email</div>
              <div class="v"><a href="mailto:sync.dyna@gmail.com">sync.dyna@gmail.com</a></div>
            </div>
          </div>
          <div class="info-item">
            <div class="ii-ico">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2Z"></path>
              </svg>
            </div>
            <div>
              <div class="k">Phone</div>
              <div class="v"><a href="tel:+60186655655">+60 18-665 5655</a></div>
            </div>
          </div>
          <div class="info-item">
            <div class="ii-ico">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8FACFF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 2"></path>
              </svg>
            </div>
            <div>
              <div class="k">Working hours</div>
              <div class="v">Mon – Fri, 8:00 am – 5:00 pm</div>
            </div>
          </div>
        </div>
        </div>
        <div class="reveal">
          <div class="form-card">
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

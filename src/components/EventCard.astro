---
import type { Event } from '../lib/catalog';

interface Props {
  event: Event;
}

const { event } = Astro.props;
---

<a class="evcard reveal" href={`/events/${event.id}`}>
  {
    event.featuredImage ? (
      <img class="event-img" src={event.featuredImage} alt="" loading="lazy" decoding="async" />
    ) : (
      <div class="ph ph--center" data-label={event.title} />
    )
  }
  <div class="evcard-body">
    <div class="ev-top">
      <span class="ev-date">{event.date}</span>
    </div>
    <h4>{event.title}</h4>
    <p>{event.excerpt}</p>
  </div>
</a>

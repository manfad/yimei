          Selangor, Malaysia<br /><br />
          <a href="mailto:contact@yimei-env.com">contact@yimei-env.com</a><br />
          +60 0-000 0000
        </address>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} Yimei Environment Protection. All rights reserved.</p>
      <div class="fb-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="/contact">Contact</a>
      </div>

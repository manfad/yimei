---
import { categoryName, type Product } from '../lib/catalog';

interface Props {
  product: Product;
  hidden?: boolean;
}

const { product, hidden = false } = Astro.props;
---

<a
  class:list={['pcard', 'reveal', { 'is-hidden': hidden }]}
  href={`/products/${product.id}`}
  data-product-cat={product.cat}
>
  <div class="pcard__media">
    {
      product.featuredImage ? (
        <img class="pimg pimg--photo" src={product.featuredImage} alt="" loading="lazy" decoding="async" />
      ) : (
        <div class="pimg ph ph--center" data-label="img" />
      )
    }
  </div>
  <div class="pcard__body">
    <div class="pc-cat">{categoryName(product.cat)}</div>
    <h4>{product.name}</h4>
  </div>
</a>
